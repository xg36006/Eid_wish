<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eid Mubarak</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
overflow:hidden;
height:100vh;
background:
linear-gradient(rgba(0,0,0,.55),rgba(0,0,0,.55)),
url('https://images.unsplash.com/photo-1513151233558-d860c5398176?q=80&w=1600&auto=format&fit=crop');
background-size:cover;
background-position:center;
color:white;
}

/* Animated Lights */

.lights span{
position:absolute;
width:8px;
height:8px;
border-radius:50%;
background:white;
box-shadow:0 0 20px white;
animation:float 8s linear infinite;
opacity:.8;
}

@keyframes float{
0%{
transform:translateY(100vh) scale(0);
opacity:0;
}
20%{
opacity:1;
}
100%{
transform:translateY(-100px) scale(1.5);
opacity:0;
}
}

/* Moon */

.moon{
position:absolute;
top:40px;
right:40px;
width:120px;
height:120px;
border-radius:50%;
background:#fff7c2;
box-shadow:
0 0 30px #fff7c2,
0 0 80px #fff7c2;
animation:moonGlow 3s infinite alternate;
}

@keyframes moonGlow{
from{
transform:scale(1);
}
to{
transform:scale(1.08);
}
}

/* Main Pages */

.page{
position:absolute;
width:100%;
height:100%;
display:flex;
justify-content:center;
align-items:center;
padding:20px;
transition:1s;
}

.hidden{
opacity:0;
pointer-events:none;
transform:scale(.8);
}

/* Glass Card */

.card{
width:100%;
max-width:420px;
padding:35px;
border-radius:30px;
background:rgba(255,255,255,0.08);
backdrop-filter:blur(15px);
border:1px solid rgba(255,255,255,.2);
text-align:center;
box-shadow:0 0 40px rgba(0,0,0,.5);
animation:cardFloat 4s ease-in-out infinite;
}

@keyframes cardFloat{
0%{
transform:translateY(0px);
}
50%{
transform:translateY(-10px);
}
100%{
transform:translateY(0px);
}
}

.logo{
font-size:70px;
margin-bottom:10px;
animation:rotate 10s linear infinite;
}

@keyframes rotate{
100%{
transform:rotate(360deg);
}
}

h1{
font-size:38px;
margin-bottom:10px;
background:linear-gradient(to right,#fff,#00ffbf);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

p{
font-size:15px;
opacity:.9;
margin-bottom:20px;
line-height:1.6;
}

input{
width:100%;
padding:15px;
border:none;
outline:none;
border-radius:15px;
background:rgba(255,255,255,.15);
color:white;
font-size:16px;
text-align:center;
margin-bottom:18px;
}

input::placeholder{
color:#ddd;
}

button{
padding:15px 30px;
border:none;
border-radius:15px;
font-size:16px;
font-weight:700;
cursor:pointer;
background:linear-gradient(45deg,#00ffbf,#00bfff);
color:black;
transition:.4s;
box-shadow:0 0 20px rgba(0,255,191,.5);
}

button:hover{
transform:scale(1.08);
box-shadow:0 0 40px rgba(0,255,191,.9);
}

/* Wish Page */

#wishName{
font-size:42px;
font-weight:700;
margin:15px 0;
color:#00ffbf;
text-shadow:0 0 20px #00ffbf;
animation:pulse 2s infinite;
}

@keyframes pulse{
50%{
transform:scale(1.08);
}
}

.gift{
margin-top:25px;
padding:18px;
border-radius:20px;
background:rgba(255,255,255,.1);
cursor:pointer;
font-size:20px;
transition:.4s;
border:1px solid rgba(255,255,255,.2);
}

.gift:hover{
transform:scale(1.05);
background:rgba(255,255,255,.18);
}

#money{
display:none;
margin-top:25px;
font-size:42px;
font-weight:bold;
color:#00ff73;
text-shadow:
0 0 15px #00ff73,
0 0 35px #00ff73;
animation:moneyAnim .7s infinite alternate;
}

@keyframes moneyAnim{
from{
transform:scale(1);
}
to{
transform:scale(1.1);
}
}

/* Fireworks */

.firework{
position:absolute;
width:6px;
height:6px;
border-radius:50%;
background:white;
animation:explode 2s infinite;
}

@keyframes explode{
0%{
transform:scale(0);
opacity:1;
}
100%{
transform:scale(18);
opacity:0;
}
}

.footer{
position:absolute;
bottom:15px;
width:100%;
text-align:center;
font-size:13px;
opacity:.8;
}

</style>
</head>

<body>

<!-- Background Effects -->

<div class="moon"></div>

<div class="lights">
<span style="left:10%; animation-delay:0s;"></span>
<span style="left:20%; animation-delay:1s;"></span>
<span style="left:35%; animation-delay:2s;"></span>
<span style="left:50%; animation-delay:3s;"></span>
<span style="left:65%; animation-delay:4s;"></span>
<span style="left:80%; animation-delay:2s;"></span>
<span style="left:90%; animation-delay:1s;"></span>
</div>

<div class="firework" style="top:20%; left:30%;"></div>
<div class="firework" style="top:60%; left:75%; animation-delay:1s;"></div>

<!-- PAGE 1 -->

<div class="page" id="page1">

<div class="card">

<div class="logo">🕌</div>

<h1>Eid Mubarak</h1>

<p>
✨ তোমার নাম লিখো আর সুন্দর Islamic Eid Wish দেখো ❤️
</p>

<input type="text" id="nameInput" placeholder="তোমার নাম লিখ...">

<button onclick="showWish()">
ENTER
</button>

</div>

</div>

<!-- PAGE 2 -->

<div class="page hidden" id="page2">

<div class="card">

<div class="logo">🌙</div>

<h1>Eid Wishes</h1>

<div id="wishName"></div>

<p>
🤲 আল্লাহ তোর জীবন সুখ, শান্তি, রহমত আর সফলতায় ভরে দিক ❤️<br>
🌙 ঈদের প্রতিটা মুহূর্ত হোক আনন্দময় ✨
</p>

<div class="gift" onclick="showMoney()">
🎁 Tap Here To Get Eid Salami
</div>

<div id="money">
💸 ১০,০০০ টাকা সালামি 💸
</div>

</div>

</div>

<div class="footer">
Made With ❤️ For Eid
</div>

<script>

function showWish(){

let name = document.getElementById("nameInput").value;

if(name.trim() == ""){
alert("আগে নাম লিখো 😒");
return;
}

document.getElementById("wishName").innerHTML = "🌟 " + name;

document.getElementById("page1").classList.add("hidden");

document.getElementById("page2").classList.remove("hidden");

}

/* Salami */

function showMoney(){

document.getElementById("money").style.display="block";

/* Vibration */

if(navigator.vibrate){
navigator.vibrate([200,100,200]);
}

}

</script>

</body>
</html>
